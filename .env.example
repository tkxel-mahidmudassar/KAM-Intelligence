# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://kam_user:kam_password@localhost:3306/kam_intelligence"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# "demo" uses seeded data + mocks | "real" enables live providers/adapters
APP_MODE="demo"

# ─── AI Provider (set ONE active provider) ───────────────────────────────────
AI_PROVIDER="openai"          # openai | claude | gemini
AI_MODEL="gpt-5.4-mini"       # overrides per-provider default

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# ─── RAG / Vector DB ─────────────────────────────────────────────────────────
CHROMA_URL="http://localhost:8000"

# ─── Integration Adapters (mock | live) ──────────────────────────────────────
SALESFORCE_ADAPTER="mock"
JIRA_ADAPTER="mock"
WORKSPHERE_ADAPTER="mock"
FINANCE_ADAPTER="mock"
