generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ASSOCIATE
  KAM
  MANAGER
  EXECUTIVE
  ADMIN
}

enum AccountHealth {
  HEALTHY
  AT_RISK
  CRITICAL
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  DONE
  DISMISSED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionSource {
  AI_PROPOSED
  HUMAN_CREATED
  PLAYBOOK
}

enum SignalType {
  REVENUE_DROP
  ENGAGEMENT_LOW
  TICKET_SPIKE
  NPS_DECLINE
  CONTRACT_EXPIRY
  CHURN_RISK
  UPSELL_OPPORTUNITY
  RELATIONSHIP_CHANGE
  HEALTH_ALERT
  CUSTOM
}

enum SignalSeverity {
  INFO
  WARNING
  CRITICAL
}

enum DocumentType {
  CONTRACT
  SOW
  MSA
  NDA
  PROPOSAL
  QBR_DECK
  OTHER
}

enum QbrType {
  QBR
  DBR
  EBR
}

enum QbrStatus {
  DRAFT
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum KycStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum InsightType {
  RISK
  OPPORTUNITY
  TREND
  ANOMALY
  RECOMMENDATION
}

enum PlaybookScope {
  GLOBAL
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String
  role               Role     @default(KAM)
  avatarUrl          String?
  phone              String?
  jobTitle           String?
  managerId          String?  // For ASSOCIATE: their supervising KAM; for KAM: their MANAGER
  notificationPrefs  Json?    // { healthDrops: bool, newSignals: bool, actionReminders: bool }
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  manager         User?          @relation("UserReportsTo", fields: [managerId], references: [id], onDelete: SetNull)
  reports         User[]         @relation("UserReportsTo")
  managedAccounts Account[]      @relation("AccountKam")
  associateAccounts Account[]    @relation("AccountAssociateOwner")
  actions         Action[]       @relation("ActionOwner")
  qbrSessions     QbrSession[]   @relation("QbrCreator")
  kycVersions     KycVersion[]   @relation("KycAuthor")
  activityLogs    ActivityLog[]
  playbooks       Playbook[]     @relation("PlaybookUploader")

  @@map("users")
}

// ─── Account ──────────────────────────────────────────────────────────────────

model Account {
  id              String        @id @default(uuid())
  sourceKey       String?       @unique
  name            String
  industry        String?
  segment         String?
  deliveryModel   String?
  currentWork     String?       @db.Text
  relationshipSignal String?    @db.Text
  region          String?
  country         String?
  logoUrl         String?
  website         String?
  arr             Float         @default(0)
  contractStart   DateTime?
  contractEnd     DateTime?
  health          AccountHealth @default(HEALTHY)
  healthUpdatedAt DateTime?
  kamId           String?
  associateOwnerId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  kam          User?            @relation("AccountKam", fields: [kamId], references: [id])
  associateOwner User?          @relation("AccountAssociateOwner", fields: [associateOwnerId], references: [id], onDelete: SetNull)
  contacts     AccountContact[]
  resources    AccountResource[]
  journeyItems AccountJourneyItem[]
  kpiDimensions KpiDimension[]
  kamScores    KamScore[]
  actions      Action[]
  signals      Signal[]
  documents    Document[]
  kycVersions  KycVersion[]
  qbrSessions  QbrSession[]
  insights               AIPulseInsight[]
  activityLogs           ActivityLog[]
  touchpoints            Touchpoint[]
  scoreOverrides         ScoreOverride[]
  questionnaireResponses QuestionnaireResponse[]
  escalations            Escalation[]
  opportunities          Opportunity[]
  recommendations        Recommendation[]
  playbookExclusions     AccountPlaybookExclusion[]
  ruleSuppression        AccountRuleSuppression[]
  feedbacks              RecommendationFeedback[]

  @@map("accounts")
}

// ─── Account Contact ──────────────────────────────────────────────────────────

model AccountContact {
  id        String   @id @default(uuid())
  accountId String
  name      String
  title     String?
  email     String?
  phone     String?
  location  String?
  timeZone  String?
  hierarchyRank Int?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_contacts")
}

model AccountResource {
  id        String   @id @default(uuid())
  accountId String
  name      String
  role      String?
  pod       String?
  location  String?
  startDate String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_resources")
}

model AccountJourneyItem {
  id          String   @id @default(uuid())
  accountId   String
  title       String
  type        String
  dateLabel   String?
  detail      String?  @db.Text
  status      String   @default("UPCOMING")
  sortOrder   Int      @default(0)
  completedAt DateTime?
  dismissReason String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("account_journey_items")
}

// ─── KPI Dimensions ───────────────────────────────────────────────────────────

model KpiDimension {
  id         String   @id @default(uuid())
  accountId  String
  name       String
  category   String
  value      Float
  target     Float?
  unit       String?
  trend      String?
  trendPct   Float?
  period     String?
  source     String?
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("kpi_dimensions")
}

// ─── KAM Score ────────────────────────────────────────────────────────────────

model KamScore {
  id             String        @id @default(uuid())
  accountId      String
  overall        Float
  // 8-KPI model (PRD v3)
  csat           Float?   // 20% weight — customer satisfaction and client sentiment
  relationship   Float?   // 15% weight — stakeholder engagement, exec coverage
  risk           Float?   // 15% weight — churn signals, escalations, ticket load
  contractHealth Float?   // 15% weight — ARR utilisation, invoicing, renewal proximity
  projectHealth  Float?   // 10% weight — delivery velocity, sprint health
  resourceHealth Float?   // 10% weight — active users, platform adoption
  financial      Float?   // 10% weight — revenue utilisation, overdue invoices
  whitespace     Float?   //  5% weight — expansion / upsell opportunity indicator
  health         AccountHealth
  aiNarrative    String?  @db.Text
  computedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("kam_scores")
}

// ─── Actions ──────────────────────────────────────────────────────────────────

model Action {
  id            String         @id @default(uuid())
  accountId     String
  ownerId       String?
  title         String
  description   String?        @db.Text
  status        ActionStatus   @default(OPEN)
  priority      ActionPriority @default(MEDIUM)
  source        ActionSource   @default(HUMAN_CREATED)
  aiConfidence  Float?
  dueDate       DateTime?
  completedAt   DateTime?
  dismissedAt   DateTime?
  dismissReason String?
  tags          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  account  Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner    User?           @relation("ActionOwner", fields: [ownerId], references: [id])
  comments ActionComment[]

  @@map("actions")
}

model ActionComment {
  id        String   @id @default(uuid())
  actionId  String
  authorId  String?
  content   String   @db.Text
  createdAt DateTime @default(now())

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@map("action_comments")
}

// ─── Signals ──────────────────────────────────────────────────────────────────

model Signal {
  id             String         @id @default(uuid())
  accountId      String
  type           SignalType
  severity       SignalSeverity  @default(WARNING)
  title          String
  description    String?        @db.Text
  source         String?
  metadata       Json?
  isRead         Boolean        @default(false)
  isResolved     Boolean        @default(false)
  resolvedAt     DateTime?
  resolvedNote   String?        @db.Text
  pendingReview  Boolean        @default(false)
  detectedAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("signals")
}

// ─── Documents ────────────────────────────────────────────────────────────────

model Document {
  id            String       @id @default(uuid())
  accountId     String
  name          String
  type          DocumentType @default(OTHER)
  fileUrl       String?
  fileSize      Int?
  mimeType      String?
  extractedText        String?  @db.LongText
  chromaDocId          String?
  tags                 String?
  uploadedById         String?
  extractedSignals     Json?
  affectedScores       Json?
  affectedKycSections  Json?
  signalStatus         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─── KYC Versions ─────────────────────────────────────────────────────────────

model KycVersion {
  id                   String    @id @default(uuid())
  accountId            String
  authorId             String?
  version              Int       @default(1)
  status               KycStatus @default(DRAFT)
  executiveSummary     String?   @db.Text
  businessModel        String?   @db.Text
  keyStakeholders      String?   @db.Text
  strategicGoals       String?   @db.Text
  riskFactors          String?   @db.Text
  expansionOpportunity String?   @db.Text
  // Section 7-9 (PRD v3 additions)
  csatHistory          String?   @db.Text  // CSAT and satisfaction history
  competitiveLandscape String?   @db.Text  // Competitors, displacement risk
  financialOverview    String?   @db.Text  // Contract terms, billing, ARR composition
  submittedAt          DateTime?
  approvedAt           DateTime?
  rejectionReason      String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  author  User?   @relation("KycAuthor", fields: [authorId], references: [id])

  @@map("kyc_versions")
}

// ─── QBR / DBR Sessions ───────────────────────────────────────────────────────

model QbrSession {
  id           String    @id @default(uuid())
  accountId    String
  createdById  String?
  type         QbrType   @default(QBR)
  status       QbrStatus @default(DRAFT)
  title        String
  scheduledAt  DateTime?
  conductedAt  DateTime?
  attendees    String?   @db.Text
  notes        String?   @db.Text
  aiSummary    String?   @db.Text
  recordingUrl String?
  audience     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("QbrCreator", fields: [createdById], references: [id])
  items     QbrItem[]

  @@map("qbr_sessions")
}

model QbrItem {
  id        String   @id @default(uuid())
  sessionId String
  order     Int      @default(0)
  category  String?
  title     String
  content   String?  @db.Text
  status    String?
  createdAt DateTime @default(now())

  session QbrSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("qbr_items")
}

// ─── AI Pulse Insights ────────────────────────────────────────────────────────

model AIPulseInsight {
  id           String      @id @default(uuid())
  accountId    String?
  type         InsightType
  title        String
  summary      String      @db.Text
  detail       String?     @db.LongText
  confidence   Float?
  model        String?
  task         String?     // e.g. "outcome-analysis", "score-narrative", "pulse-insight"
  promptTokens Int?
  outputTokens Int?
  latencyMs    Int?        // LLM call latency in ms
  isRead       Boolean     @default(false)
  isDismissed  Boolean     @default(false)
  generatedAt  DateTime    @default(now())
  createdAt    DateTime    @default(now())

  // Source attribution — what data drove this insight
  // Shape: { newsHeadlines: NewsItem[], internalData: { health, overallScore, keyScores, signalTitles } }
  sources      Json?

  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@map("ai_pulse_insights")
}

// ─── Touchpoints ──────────────────────────────────────────────────────────────

model Touchpoint {
  id               String   @id @default(uuid())
  accountId        String
  type             String
  date             DateTime
  loggedBy         String?
  notes            String?  @db.Text
  linkedDocumentId String?
  stakeholders     String?
  createdAt        DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("touchpoints")
}

// ─── Score Overrides ──────────────────────────────────────────────────────────

model ScoreOverride {
  id             String   @id @default(uuid())
  accountId      String
  kpiKey         String
  previousValue  Float
  requestedValue Float
  approvedValue  Float?
  reason         String   @db.Text
  requestedById  String?
  approvedById   String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("score_overrides")
}

// ─── Questionnaire Responses ──────────────────────────────────────────────────

model QuestionnaireResponse {
  id           String   @id @default(uuid())
  accountId    String
  section      String
  questionId   String
  response     String   @db.Text
  inputType    String
  prepopulated Boolean  @default(false)
  confidence   Float?
  confirmedBy  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("questionnaire_responses")
}

// ─── Escalations ──────────────────────────────────────────────────────────────

model Escalation {
  id              String    @id @default(uuid())
  accountId       String
  type            String
  severity        String    @default("MEDIUM")
  description     String    @db.Text
  linkedProject   String?
  openedById      String?
  resolutionNotes String?   @db.Text
  status          String    @default("OPEN")
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("escalations")
}

// ─── Opportunities ────────────────────────────────────────────────────────────

model Opportunity {
  id             String    @id @default(uuid())
  accountId      String
  serviceLine    String
  description    String    @db.Text
  estimatedValue Float?
  effort         String?
  probability    Float?
  status         String    @default("IDENTIFIED")
  source         String    @default("AI")
  nextAction     String?
  pendingReview  Boolean   @default(false)
  reviewedAt     DateTime?
  reviewNote     String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("opportunities")
}

// ─── App Config (global settings, single row) ─────────────────────────────────

model AppConfig {
  id                  String   @id @default("global")
  // Score weights — percentages (integers), must sum to 100
  // Keys: csat | relationship | risk | contractHealth | projectHealth | resourceHealth | financial | whitespace
  scoreWeights        Json?
  // Notification preferences — per-event toggles, frequency, channels
  notificationPrefs   Json?
  updatedAt           DateTime @updatedAt
  updatedBy           String?

  @@map("app_config")
}

// ─── Playbooks ────────────────────────────────────────────────────────────────

model Playbook {
  id          String         @id @default(uuid())
  title       String
  scope       String         @default("GLOBAL")
  fileName    String
  fileType    String         // pdf | docx | txt | md | xlsx
  mimeType    String
  fileSize    Int
  storagePath String
  uploadedById String?
  status      PlaybookStatus @default(PROCESSING)
  processedAt DateTime?
  errorMessage String?       @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  uploadedBy  User?          @relation("PlaybookUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  rules       PlaybookRule[]
  exclusions  AccountPlaybookExclusion[]

  @@map("playbooks")
}

enum PlaybookStatus {
  PROCESSING
  ACTIVE
  PENDING_REVIEW  // at least one rule needs manager approval before playbook is fully active
  FAILED
  ARCHIVED
}

model PlaybookRule {
  id               String   @id @default(uuid())
  playbookId       String
  category         String   // CSAT | RELATIONSHIP | RISK | CONTRACT | PROJECT | RESOURCE | FINANCIAL | WHITESPACE | RENEWAL | DELIVERY | GROWTH
  condition        String   @db.Text
  recommendation   String   @db.Text
  correctiveMeasure String? @db.Text
  priority         Int      @default(2) // 1=HIGH 2=MEDIUM 3=LOW
  sourceTitle      String?
  sourcePage       Int?
  sourceSection    String?
  sourceSheet      String?
  sourceExcerpt    String?  @db.Text
  createdAt        DateTime @default(now())

  // Validation status (set by playbookExtractor field validators)
  status                  String  @default("ACTIVE") // ACTIVE | PENDING_REVIEW
  validationFailureReason String? @db.Text           // why the rule was sent to PENDING_REVIEW

  // Source checker fields (set by sourceChecker agent — Item 7)
  sourceConfidence  Float?  // 0.0-1.0; null until source checker has run
  sourceMismatch    String? @db.Text  // mismatch reason if confidence < 0.7
  suggestedCategory String? // source checker's suggested category correction if wrong

  // Quality tracking (updated by Rule Quality Scorer agent)
  qualityScore     Float?           // 0-100; null until >= 5 feedback signals exist
  dismissCount     Int              @default(0)
  actionCount      Int              @default(0)
  qualityNote      Json?            // { summary, suggestions, flag?, analyzedAt }

  playbook         Playbook          @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  recommendations  Recommendation[]
  feedbacks        RecommendationFeedback[]
  suppressions     AccountRuleSuppression[]

  @@map("playbook_rules")
}

// Per-account playbook exclusion (user decision: global playbooks can be deactivated per account)
model AccountPlaybookExclusion {
  id         String   @id @default(uuid())
  accountId  String
  playbookId String
  createdAt  DateTime @default(now())

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  playbook Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@unique([accountId, playbookId])
  @@map("account_playbook_exclusions")
}

model Recommendation {
  id               String             @id @default(uuid())
  accountId        String
  sourceType       RecommendationSource @default(AI_FALLBACK)
  playbookRuleId   String?
  title            String
  summary          String             @db.Text
  recommendedAction String?           @db.Text
  priority         Int                @default(2) // 1=HIGH 2=MEDIUM 3=LOW
  dueDate          DateTime?
  status           RecommendationStatus @default(ACTIVE)
  confidence       Float?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Expiry + score-version linkage (Item 6)
  category          String?   // KPI dimension being addressed — used to watch for score recovery
  expiresAt         DateTime? // set at creation; auto-expired when KPI recovers >= 70 OR 30 days elapsed
  expiryReason      String?   // "CSAT recovered to 74" | "30 days elapsed"
  triggeringScoreId String?   // FK to the KamScore that triggered this recommendation

  account          Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  playbookRule     PlaybookRule?      @relation(fields: [playbookRuleId], references: [id], onDelete: SetNull)
  feedbacks        RecommendationFeedback[]

  @@map("recommendations")
}

enum RecommendationSource {
  PLAYBOOK
  AI_FALLBACK
}

enum RecommendationStatus {
  ACTIVE
  ACTIONED
  DISMISSED
  EXPIRED
}

// ─── Phase 5: Feedback Loop Models ───────────────────────────────────────────

enum FeedbackType {
  ACTIONED
  DISMISSED
  ACTION_COMPLETED
  ACTION_DISMISSED
}

enum DismissReason {
  IRRELEVANT
  ALREADY_DONE
  WRONG_TIMING
  OTHER
}

enum RuleCandidateStatus {
  PENDING
  PROMOTED
  DISMISSED
}

// Captures explicit + implicit feedback on recommendations
model RecommendationFeedback {
  id               String       @id @default(uuid())
  recommendationId String
  playbookRuleId   String?      // null for AI_FALLBACK recs
  accountId        String
  feedbackType     FeedbackType
  dismissReason    DismissReason?
  annotationText   String?      @db.Text  // LLM interpretation (skipped on failure)
  annotationModel  String?
  healthBefore     Float?
  healthAfter      Float?
  createdAt        DateTime     @default(now())

  recommendation   Recommendation  @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  playbookRule     PlaybookRule?   @relation(fields: [playbookRuleId], references: [id], onDelete: SetNull)
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("recommendation_feedbacks")
}

// Per-account rule suppression — created on explicit KAM request after 2+ dismissals
model AccountRuleSuppression {
  id             String    @id @default(uuid())
  accountId      String
  playbookRuleId String
  reason         String    // e.g. "Dismissed 2x — KAM suppressed"
  suppressedAt   DateTime  @default(now())
  liftedAt       DateTime?
  liftedBy       String?   // role string

  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  playbookRule   PlaybookRule @relation(fields: [playbookRuleId], references: [id], onDelete: Cascade)

  @@unique([accountId, playbookRuleId])
  @@map("account_rule_suppressions")
}

// AI_FALLBACK patterns crystallized into candidate playbook rules
model RuleCandidate {
  id                  String               @id @default(uuid())
  title               String
  category            String
  condition           String               @db.Text
  recommendation      String               @db.Text
  sourceCount         Int                  @default(1)  // distinct accounts
  accountIds          Json?                // array of accountIds that contributed
  confidence          Float?
  clusterKey          String?              // "CATEGORY::first-four-title-words" — used for sub-cluster dedup
  status              RuleCandidateStatus  @default(PENDING)
  promotedToRuleId    String?              // PlaybookRule.id after promotion
  promotedToPlaybookId String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("rule_candidates")
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  accountId String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}
